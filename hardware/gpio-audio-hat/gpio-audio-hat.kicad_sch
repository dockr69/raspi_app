  (text "── WM8960 Audio Codec ──" (at 155.00 55.00 0) (effects (font (size 2.0 2.0) bold)))
  (text "Power Decoupling" (at 230.00 85.00 0) (effects (font (size 2.0 2.0) bold)))
  (text "── Audio Input (Line In) ──" (at 290.00 30.00 0) (effects (font (size 2.0 2.0) bold)))
  (text "── Audio Output (Line Out) ──" (at 290.00 100.00 0) (effects (font (size 2.0 2.0) bold)))
  (text "── GPIO Taster (Schraubklemmen + RC-Entprellung) ──" (at 30.00 200.00 0) (effects (font (size 2.0 2.0) bold)))
  (text "── Hinweise ──" (at 290.00 170.00 0) (effects (font (size 2.0 2.0) bold)))
  (text "ESD: TVS-Dioden (z.B. PESD5V0S2BT) an Audio-Ein-/Ausgängen empfohlen" (at 290 180 0) (effects (font (size 1.5 1.5))))
  (text "Audio-Qualität: Film-Kondensatoren (C7,C8) für klangfreien Eingang" (at 290 186 0) (effects (font (size 1.5 1.5))))
  (text "GPIO: RC-Entprellung (10k + 100nF, τ≈1ms) für sauberes Schalten" (at 290 192 0) (effects (font (size 1.5 1.5))))
  (text "WM8960 Addr: CSB→GND = 0x1A / CSB→3V3 = 0x1B" (at 290 198 0) (effects (font (size 1.5 1.5))))
  (text "I2S: ADCLRC + DACLRC verbunden (gemeinsamer LRCLK)" (at 290 204 0) (effects (font (size 1.5 1.5))))
  (text "MCLK: Nicht verbunden – WM8960 PLL leitet Clock von BCLK ab" (at 290 210 0) (effects (font (size 1.5 1.5))))
